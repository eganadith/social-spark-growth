# Supabase (browser — anon key only in the Vite app)
# Must be the SAME project where you deploy Edge Functions (`create-ziina-payment`, `verify-payment`) or invokes return 401.
#VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#VITE_SUPABASE_ANON_KEY=your-anon-key

# Production: canonical public URL (no trailing slash). Required for correct email confirmation redirects on Netlify.
# VITE_SITE_URL=https://your-app.netlify.app

# Optional: same as pro-run-store — enables Ziina test intents in production builds when needed.
# VITE_PAYMENT_TEST_MODE=true

# --- Ziina checkout (Supabase Edge Function secrets; set via Dashboard → Edge Functions → Secrets or `supabase secrets set`)
# Never put ZIINA_API_KEY in Vite env — it must stay server-side only.
# ZIINA_API_KEY=your-ziina-api-key
# ZIINA_TEST_MODE=true
# SITE_URL optional if the app sends success/cancel URLs (default). Fallback when client omits URLs.
# SITE_URL=https://your-app.netlify.app
# Extra hostnames allowed for those URLs (comma-separated), e.g. your custom domain + preview host.
# ZIINA_ALLOWED_DOMAINS=your-app.netlify.app,www.yourdomain.com

# Resend (Edge Function `verify-payment` — confirmation email after paid)
# RESEND_API_KEY=re_...
# RESEND_FROM=Socioly <orders@your-verified-domain.com>

# Optional: only if `npm run db:seed` / `supabase link` asks for the database password
# (Dashboard → Project Settings → Database → Database password)
# SUPABASE_DB_PASSWORD=
