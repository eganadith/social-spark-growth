# Supabase (browser — anon key only in the Vite app)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: with `npm run dev` only — skip create-payment; save a pending order and go to Track (ignored in production builds)
# VITE_DEV_LOCAL_CHECKOUT=true

# Optional: only if `npm run db:seed` / `supabase link` asks for the database password
# (Dashboard → Project Settings → Database → Database password)
# SUPABASE_DB_PASSWORD=

# Edge Functions secrets (Supabase Dashboard → Edge Functions → Secrets)
# SUPABASE_SERVICE_ROLE_KEY=
# ZIINA_API_KEY=          # Bearer token from Ziina (Payment Intents)
# ZIINA_WEBHOOK_SECRET=  # Optional: if you register Ziina webhooks (polling is primary)
# PUBLIC_SITE_URL=https://yourdomain.com
# ZIINA_TEST=true         # Optional: test payment intents (no real charge)
# ZIINA_API_BASE=         # Optional: default https://api-v2.ziina.com/api
# PAYMENTS_POLL_SECRET=   # Required for poll-pending-payments (header x-socioly-poll or Bearer)
# PAYMENT_PENDING_TTL_HOURS=24  # Pending Ziina intents older than this are marked failed by the poller
# BOOSTING_WEBHOOK_URL=   # Optional POST when payment completes (fulfillment provider)